# fm-agent runtime config — gitignored, do not commit.
# Keys map to constants in config.py via os.environ.get(...) + python-dotenv.

# LLM endpoint. The example below uses OpenRouter; for other providers
# (and prompt-cache setup) see docs/config_llm.md.
LLM_API_KEY=YOUR_LLM_API_KEY
LLM_API_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-sonnet-4.6

# OpenCode provider prefix — must match a provider registered in
# ~/.config/opencode/opencode.json.
OPENCODE_MODEL_PROVIDER=openrouter
